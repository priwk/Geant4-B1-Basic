#/process/inactivate nKiller

/run/initialize

/process/had/particle_hp/skip_missing_isotopes true
/process/had/particle_hp/do_not_adjust_final_state true

/gps/particle neutron
/gps/ene/type Mono
/gps/ene/mono 0.0253 eV

/gps/pos/type Point
/gps/pos/centre 0 0 5 cm

/gps/direction 0 0 -1

/tracking/verbose 1
/run/beamOn 1