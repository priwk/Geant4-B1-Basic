/run/reinitializeGeometry
/run/initialize
/run/beamOn 10000

/det/setThickness 300 um
/run/reinitializeGeometry
/run/initialize
/run/beamOn 10000

/det/setThickness 400 um
/run/reinitializeGeometry
/run/initialize
/run/beamOn 10000

